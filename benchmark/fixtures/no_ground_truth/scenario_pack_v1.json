  "monotonicity_rules": [
    {
      "rule_id": "near_structure_vegetation_increase_non_decrease_risk",
      "description": "Increasing near-structure vegetation should not reduce overall risk.",
      "baseline": "mono_veg_low",
      "variant": "mono_veg_high",
      "metric": "scores.wildfire_risk_score",
      "expected": "non_decrease",
      "min_magnitude": 1.0
    },
    {
      "rule_id": "slope_increase_non_decrease_site_hazard",
      "description": "Higher slope should not reduce site hazard.",
      "baseline": "mono_slope_low",
      "variant": "mono_slope_high",
      "metric": "scores.site_hazard_score",
      "expected": "non_decrease",
      "min_magnitude": 1.0
    },
    {
      "rule_id": "hardening_improvement_non_increase_risk",
