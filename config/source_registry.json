{
  "version": 1,
  "name": "wildfire-default-source-registry",
  "description": "Default offline prep source registry. Override with --source-config when needed.",
  "layers": {
    "dem": {
      "provider_type": "arcgis_image_service",
      "source_endpoint": "${WF_DEFAULT_DEM_ENDPOINT:-https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer}",
      "full_download_url": "${WF_DEFAULT_DEM_FULL_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "target_resolution": 30.0,
      "expected_output_format": "tif",
      "notes": "USGS 3DEP image service default. Override with WF_DEFAULT_DEM_ENDPOINT if needed."
    },
    "fuel": {
      "provider_type": "arcgis_image_service",
      "source_endpoint": "${WF_DEFAULT_FUEL_ENDPOINT:-https://lfps.usgs.gov/arcgis/rest/services/Landfire_LF240/US_240FBFM40/ImageServer}",
      "full_download_url": "${WF_DEFAULT_FUEL_FULL_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "target_resolution": 30.0,
      "expected_output_format": "tif",
      "notes": "LANDFIRE LF240 fuel model image service (USGS LFPS). Override WF_DEFAULT_FUEL_ENDPOINT for alternate snapshots."
    },
    "canopy": {
      "provider_type": "arcgis_image_service",
      "source_endpoint": "${WF_DEFAULT_CANOPY_ENDPOINT:-https://lfps.usgs.gov/arcgis/rest/services/Landfire_LF240/US_240CC/ImageServer}",
      "full_download_url": "${WF_DEFAULT_CANOPY_FULL_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "target_resolution": 30.0,
      "expected_output_format": "tif",
      "notes": "LANDFIRE LF240 canopy cover image service (USGS LFPS). Override WF_DEFAULT_CANOPY_ENDPOINT for alternate snapshots."
    },
    "fire_perimeters": {
      "provider_type": "arcgis_feature_service",
      "source_endpoint": "${WF_DEFAULT_FIRE_PERIMETERS_ENDPOINT:-https://services3.arcgis.com/T4QMspbfLg3qTGWY/arcgis/rest/services/InterAgencyFirePerimeterHistory_All_Years_View/FeatureServer/0}",
      "full_download_url": "${WF_DEFAULT_FIRE_PERIMETERS_FULL_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "query_format": "json",
      "supports_geojson_direct": false,
      "require_return_geometry": true,
      "expected_output_format": "geojson",
      "notes": "NIFC perimeter feature-service default. Override with WF_DEFAULT_FIRE_PERIMETERS_ENDPOINT if needed."
    },
    "building_footprints": {
      "provider_type": "arcgis_feature_service",
      "source_endpoint": "${WF_DEFAULT_BUILDING_FOOTPRINTS_ENDPOINT:-https://services2.arcgis.com/FiaPA4ga0iQKduv3/arcgis/rest/services/USA_Structures_View/FeatureServer/0}",
      "full_download_url": "${WF_DEFAULT_BUILDING_FOOTPRINTS_FULL_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "query_format": "json",
      "supports_geojson_direct": false,
      "require_return_geometry": true,
      "expected_output_format": "geojson",
      "notes": "Public USA structures feature-service default (fallback for building-footprint context)."
    },
    "building_footprints_overture": {
      "provider_type": "arcgis_feature_service",
      "source_path": "${WF_DEFAULT_OVERTURE_BUILDINGS_PATH:-}",
      "source_endpoint": "${WF_DEFAULT_OVERTURE_BUILDINGS_ENDPOINT:-}",
      "source_url": "${WF_DEFAULT_OVERTURE_BUILDINGS_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "query_format": "json",
      "supports_geojson_direct": false,
      "require_return_geometry": true,
      "expected_output_format": "geojson",
      "notes": "Preferred Overture Maps building source. Supports local GeoJSON path or a bbox-capable feature service endpoint."
    },
    "parcel_polygons": {
      "provider_type": "arcgis_feature_service",
      "source_path": "${WF_DEFAULT_PARCEL_POLYGONS_PATH:-}",
      "source_endpoint": "${WF_DEFAULT_PARCEL_POLYGONS_ENDPOINT:-}",
      "source_url": "${WF_DEFAULT_PARCEL_POLYGONS_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "query_format": "json",
      "supports_geojson_direct": false,
      "require_return_geometry": true,
      "expected_output_format": "geojson",
      "notes": "Optional parcel boundaries. Supports local GeoJSON path or a bbox-capable feature service endpoint."
    },
    "parcel_address_points": {
      "provider_type": "arcgis_feature_service",
      "source_path": "${WF_DEFAULT_PARCEL_ADDRESS_POINTS_PATH:-}",
      "source_endpoint": "${WF_DEFAULT_PARCEL_ADDRESS_POINTS_ENDPOINT:-}",
      "source_url": "${WF_DEFAULT_PARCEL_ADDRESS_POINTS_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "query_format": "json",
      "supports_geojson_direct": false,
      "require_return_geometry": true,
      "expected_output_format": "geojson",
      "notes": "Optional authoritative address/parcel points used to improve property anchors. Supports local points GeoJSON or a feature service endpoint."
    },
    "roads": {
      "provider_type": "arcgis_feature_service",
      "source_endpoint": "${WF_DEFAULT_ROADS_ENDPOINT:-https://services.arcgis.com/xOi1kZaI0eWDREZv/ArcGIS/rest/services/NTAD_North_American_Roads/FeatureServer/0}",
      "full_download_url": "${WF_DEFAULT_ROADS_FULL_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "query_format": "json",
      "supports_geojson_direct": false,
      "require_return_geometry": true,
      "expected_output_format": "geojson",
      "notes": "Optional roads source via NTAD FeatureServer (JSON query preferred). Override WF_DEFAULT_ROADS_ENDPOINT if needed."
    },
    "whp": {
      "provider_type": "arcgis_image_service",
      "source_endpoint": "${WF_DEFAULT_WHP_ENDPOINT:-https://imagery.geoplatform.gov/iipp/rest/services/Fire_Aviation/USFS_EDW_RMRS_WildfireHazardPotentialClassified/ImageServer}",
      "full_download_url": "${WF_DEFAULT_WHP_FULL_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "target_resolution": 30.0,
      "expected_output_format": "tif",
      "notes": "Optional USFS WHP classified image service (geoplatform replacement endpoint)."
    },
    "mtbs_severity": {
      "provider_type": "arcgis_image_service",
      "source_endpoint": "${WF_DEFAULT_MTBS_SEVERITY_ENDPOINT:-https://imagery.geoplatform.gov/iipp/rest/services/Fire_Aviation/USFS_EDW_MTBS_CONUS/ImageServer}",
      "full_download_url": "${WF_DEFAULT_MTBS_SEVERITY_FULL_URL:-}",
      "supports_bbox_export": true,
      "allow_full_download_fallback": true,
      "target_resolution": 30.0,
      "expected_output_format": "tif",
      "notes": "Optional MTBS CONUS burn-severity image service (geoplatform replacement endpoint)."
    },
    "gridmet_dryness": {
      "provider_type": "file_download",
      "source_endpoint": "${WF_DEFAULT_GRIDMET_DRYNESS_ENDPOINT:-}",
      "full_download_url": "${WF_DEFAULT_GRIDMET_DRYNESS_FULL_URL:-https://www.northwestknowledge.net/metdata/data/fm1000_2026.nc}",
      "supports_bbox_export": false,
      "allow_full_download_fallback": true,
      "target_resolution": 4000.0,
      "expected_output_format": "tif",
      "notes": "Optional gridMET dryness proxy. Default is annual fm1000 NetCDF snapshot (override WF_DEFAULT_GRIDMET_DRYNESS_FULL_URL for a different year/source)."
    }
  }
}
