# WildfireRisk Advisor — Environment Variables
# Copy to .env for local development. Never commit real secrets.

# === REQUIRED FOR PRODUCTION ===
WF_ALLOWED_ORIGINS=https://your-frontend-domain.com
WILDFIRE_API_KEYS=dev-key-1

# === EXTERNAL SERVICES ===
WF_GOOGLE_GEOCODE_API_KEY=
WF_REGRID_API_KEY=
OPENAI_API_KEY=

# === RATE LIMITING ===
WF_RATE_LIMIT_ASSESS=10/minute
WF_RATE_LIMIT_ASSESS_DAILY=100/day
WF_RATE_LIMIT_SIMULATE=20/minute
WF_RATE_LIMIT_BYPASS_KEYS=
WF_REDIS_URL=memory://

# === CORE DATA PATHS / FLAGS ===
WF_MTBS_GPKG_PATH=data/national/mtbs_perimeters.gpkg
# Fire history lazy loading — CRITICAL for memory-constrained deployments
# The MTBS dataset loads ~1.4GB RSS. Keep true for Railway/Render starter tiers.
WF_FIRE_HISTORY_LAZY_LOAD=true
WF_PARCEL_CACHE_DB=data/parcel_cache.db
WF_FOOTPRINT_CACHE_DB=data/footprint_cache.db
WF_LANDFIRE_CACHE_DB=data/landfire_cache.db
WF_ELEVATION_CACHE_DB=data/elevation_cache.db
WF_NLCD_CACHE_DB=data/nlcd_cache.db
WF_LANDFIRE_COG_ENABLED=true
WF_ELEVATION_COG_ENABLED=true
WF_NLCD_COG_ENABLED=true
WF_WHP_PROXY_ENABLED=true
WF_DEBUG_ERRORS=false

# === ALL OTHER BACKEND VARIABLES (optional; uncomment as needed) ===
